# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for fursat-ws-detector
# Copy to .env (local dev) or set in Railway dashboard (production)
# ─────────────────────────────────────────────────────────────────────────────

# Upstash Redis REST API (same instance as fursat.net, but worker only writes
# to keys under the dryrun:* namespace).
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Coinbase CDP credentials (same as fursat.net) — REQUIRED for WS authentication.
# Without these, Coinbase Advanced WS pushes only sporadic events instead of a
# full tick stream.
#
# COINBASE_API_KEY format: organizations/<org-id>/apiKeys/<key-id>
# COINBASE_API_SECRET format: PEM-encoded EC private key (BEGIN EC PRIVATE KEY...)
# In .env files, store with literal \n separators — the worker auto-converts to real newlines.
COINBASE_API_KEY=organizations/xxx/apiKeys/yyy
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nMHcCAQEE...\n-----END EC PRIVATE KEY-----\n

# HTTP health server port (Railway injects PORT automatically; fallback 8080 for local)
PORT=8080

# Logging verbosity: "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# Optional: comma-separated list of symbols to override product discovery (testing)
# Example: BTC,ETH,SOL — leave empty to subscribe to all *-USDC tradable products
SYMBOL_OVERRIDE=
